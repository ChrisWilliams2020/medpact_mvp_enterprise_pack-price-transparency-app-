# =============================================================================
# MedPact Practice Intelligence - Environment Variables
# =============================================================================
# Copy this file to .env and update the values for your environment

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql+pg8000://medpact:medpact@localhost:5432/medpact

# -----------------------------------------------------------------------------
# Redis Configuration (for job queue and pub/sub)
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0

# -----------------------------------------------------------------------------
# MinIO / S3 Configuration (for file uploads)
# -----------------------------------------------------------------------------
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minio
MINIO_SECRET_KEY=minio123
MINIO_BUCKET=uploads
MINIO_SECURE=false

# -----------------------------------------------------------------------------
# Auth0 / OIDC Configuration
# Set AUTH_ENABLED=true to require authentication (production)
# Leave AUTH_ENABLED=false for development (uses X-Practice-Id header)
# -----------------------------------------------------------------------------
AUTH_ENABLED=false

# Auth0 Configuration (required if AUTH_ENABLED=true)
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_CLIENT_ID=your-client-id
AUTH0_CLIENT_SECRET=your-client-secret
AUTH0_AUDIENCE=https://api.medpact.ai
AUTH0_CALLBACK_URL=http://localhost:8000/auth/callback

# Session cookie secret (change in production!)
AUTH_COOKIE_SECRET=dev-secret-change-in-production

# -----------------------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------------------
ENV=development
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# Docker Compose URLs (used when running in containers)
# Uncomment these when using docker-compose
# -----------------------------------------------------------------------------
# DATABASE_URL=postgresql+pg8000://medpact:medpact@postgres:5432/medpact
# REDIS_URL=redis://redis:6379/0
# MINIO_ENDPOINT=minio:9000
