
{
  "builds": [
    {
      "src": "apps/web/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "apps/web/dist" }
    },
    {
      "src": "apps/*/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    }
  ],
  "routes": [
    { "src": "/(.*)", "dest": "/apps/web/$1" }
  ],
  "github": {
    "silent": false
  },
  "rootDirectory": "apps/web"
}
