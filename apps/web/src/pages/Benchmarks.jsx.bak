                  </div>
                </div>
              ))}
            </div>
          </div>
        ))}

        {selected && (
          <div style={{ 
            background: 'white', 
            padding: '24px', 
            borderRadius: '12px', 
            border: '1px solid #e5e7eb', 
            position: 'sticky', 
            bottom: '20px', 
