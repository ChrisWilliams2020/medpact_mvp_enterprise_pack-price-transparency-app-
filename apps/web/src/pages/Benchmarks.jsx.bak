              )}
              <div style={{ marginLeft: 'auto', fontSize: '13px', color: '#6b7280' }}>
                Benchmark: <span style={{ fontWeight: 600, color: COLORS.peAsc.solid }}>
                  {typeof selected.benchmark === 'number' && selected.benchmark >= 1000 ? selected.benchmark.toLocaleString() : selected.benchmark} {selected.unit}
                </span>
