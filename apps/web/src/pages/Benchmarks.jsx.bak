// Progress Ring Component for visualizations
function ProgressRing({ progress, size = 80, strokeWidth = 8, color = COLORS.secondary }) {80, strokeWidth = 8, color = COLORS.secondary }) {80, strokeWidth = 8, color = COLORS.secondary }) {80, strokeWidth = 8, color = COLORS.secondary }) {
  const radius = (size - strokeWidth) / 2
  const circumference = radius * 2 * Math.PI
  const offset = circumference - (progress / 100) * circumference  const offset = circumference - (progress / 100) * circumference  const offset = circumference - (progress / 100) * circumference  const offset = circumference - (progress / 100) * circumference

  return (
    <svg width={size} height={size} style={{ transform: 'rotate(-90deg)' }}>h={size} height={size} style={{ transform: 'rotate(-90deg)' }}>h={size} height={size} style={{ transform: 'rotate(-90deg)' }}>h={size} height={size} style={{ transform: 'rotate(-90deg)' }}>
      <circle
        stroke="#e5e7eb"e7eb"e7eb"e7eb"
        fill="none"
        strokeWidth={strokeWidth}h={strokeWidth}h={strokeWidth}h={strokeWidth}
        r={radius}
        cx={size / 2}
        cy={size / 2}cy={size / 2}cy={size / 2}cy={size / 2}
      />
      <circle
        stroke={color}or}or}or}
        fill="none"
        strokeWidth={strokeWidth}dth}
        strokeLinecap="round"cap="round"cap="round"cap="round"
        r={radius}
        cx={size / 2}
        cy={size / 2} / 2} / 2} / 2}
        style={{
          strokeDasharray: circumference,rence,rence,rence,
          strokeDashoffset: offset,
          transition: 'stroke-dashoffset 0.5s ease',transition: 'stroke-dashoffset 0.5s ease',ansition: 'stroke-dashoffset 0.5s ease',transition: 'stroke-dashoffset 0.5s ease',
        }}}}}}}}
      />
    </svg> </svg>/svg> </svg>
  ) )) )
}}}}

// Benchmark Comparison Bar
function BenchmarkBar({ value, benchmark, label, color = COLORS.success }) {RS.success }) { }) {
  const percentage = Math.min((value / benchmark) * 100, 150) / benchmark) * 100, 150)ark) * 100, 150)
  const isAbove = value >= benchmarkconst isAbove = value >= benchmarkconst isAbove = value >= benchmarkconst isAbove = value >= benchmark
  
  return (
    <div style={{ marginBottom: 16 }}>
      <div style={{ display: 'flex', justifyContent: 'space-between', marginBottom: 4 }}>arginBottom: 4 }}>arginBottom: 4 }}>arginBottom: 4 }}>
        <span style={{ fontSize: 13, color: '#374151' }}>{label}</span>
        <span style={{ fontSize: 13, fontWeight: 600, color: isAbove ? COLORS.success : COLORS.warning }}>ove ? COLORS.success : COLORS.warning }}>ORS.success : COLORS.warning }}>
          {value.toLocaleString()} / {benchmark.toLocaleString()}e.toLocaleString()} / {benchmark.toLocaleString()}oLocaleString()} / {benchmark.toLocaleString()}e.toLocaleString()} / {benchmark.toLocaleString()}
        </span>an>an>an>
      </div>
      <div style={{ 
        width: '100%', %', %', %', 
        height: 8, 
        background: '#e5e7eb', e7eb', e7eb', e7eb', 
        borderRadius: 4,
        overflow: 'hidden',
        position: 'relative'osition: 'relative'osition: 'relative'osition: 'relative'
      }}>
        <div style={{
          width: `${Math.min(percentage, 100)}%`,min(percentage, 100)}%`,min(percentage, 100)}%`,min(percentage, 100)}%`,
          height: '100%',
          background: isAbove ? color : COLORS.warning,ove ? color : COLORS.warning,ove ? color : COLORS.warning,ove ? color : COLORS.warning,
          borderRadius: 4,
          transition: 'width 0.5s ease',nsition: 'width 0.5s ease',nsition: 'width 0.5s ease',nsition: 'width 0.5s ease',
        }} />
        {/* Benchmark marker */} marker */} marker */} marker */}
        <div style={{
          position: 'absolute',olute',,olute',
          left: '66.7%',6.7%',6.7%',6.7%',
          top: -2,
          width: 2,
          height: 12,
          background: '#374151',kground: '#374151',ground: '#374151',kground: '#374151',
        }} />>
      </div>v>
    </div> </div>/div> </div>
  ) )) )
}}}}

