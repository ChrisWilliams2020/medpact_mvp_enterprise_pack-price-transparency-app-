                      <td className="py-3 px-4 text-sm">{p.description}</td>
                      <td className="py-3 px-4 text-center text-blue-600">${p.commercial.avg}</td>
                      <td className="py-3 px-4 text-center text-green-600">${p.medicare}</td>
                      <td className="py-3 px-4 text-center text-orange-600">${p.medicaid}</td>
                      <td className="py-3 px-4 text-center font-medium text-purple-600">${p.yourPrice}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </div>
        )}

        {/* NEGOTIATION */}
        {activeTab === 'negotiation' && (
          <div className="bg-white rounded-xl shadow-lg p-6">
            <h2 className="text-2xl font-bold mb-6">🤝 5-Step Payer Negotiation</h2>
            <div className="flex items-center justify-between mb-8">
              {[1,2,3,4,5].map(step => (
                <div key={step} className="flex items-center">
                  <div className={`w-12 h-12 rounded-full flex items-center justify-center font-bold ${step <= 2 ? 'bg-green-500 text-white' : step === 3 ? 'bg-blue-500 text-white' : 'bg-gray-200'}`}>
                    {step <= 2 ? '✓' : step}
                  </div>
                  {step < 5 && <div className={`w-16 h-1 ${step < 3 ? 'bg-green-500' : 'bg-gray-200'}`}></div>}
                  </div>
                  {step < 5 && <div className={`w-16 h-1 ${step < 3 ? 'bg-green-500' : 'bg-gray-200'}`}></div>}
                </div>
              ))}
            </div>
            <div className="grid md:grid-cols-5 gap-4 text-center text-sm">
              <div>Data Prep</div>
              <div>Market Analysis</div>
              <div className="font-bold text-blue-600">Proposal</div>
              <div>Negotiation</div>
              <div>Finalize</div>
            </div>
          </div>
        )}
      </div>

      {/* Admin Modal (when triggered from dashboard) */}
      {showAdminModal && (
        <div className="fixed inset-0 bg-black/70 flex items-center justify-center z-50 p-4">
          <div className="bg-white rounded-2xl max-w-md w-full overflow-hidden shadow-2xl">
            <div className="bg-gradient-to-r from-purple-600 to-pink-600 p-6 text-white">
              <div className="flex items-center justify-between">
                <div className="flex items-center gap-3">
                  <span className="text-3xl">🔐</span>
                  <h2 className="text-xl font-bold">Admin Management</h2>
                </div>
                <button onClick={() => { setShowAdminModal(false); setSelectedRole(null); }} className="p-2 hover:bg-white/20 rounded-full">✕</button>
              </div>
            </div>
            <div className="p-6">
              {!selectedRole ? (
                <div className="space-y-4">
                  {[
                    { key: 'medpact-team', icon: '🏢', title: 'MedPact Team', desc: 'Full access' },
                    { key: 'owner', icon: '👤', title: 'Owner', desc: 'Payment & survey access' },
                    { key: 'admin', icon: '⚙️', title: 'Administrator', desc: 'Survey access' }
                  ].map(role => (
                    <button key={role.key} onClick={() => handleRoleSelect(role.key)} className="w-full p-4 rounded-xl border-2 text-left hover:border-purple-500 flex items-center gap-4 transition-all"><h3 className="font-semibold mb-4">Upload Data File</h3>
                        <span className="text-3xl">{role.icon}</span>
                        <div>rder-gray-300 rounded-xl p-8 text-center hover:border-purple-500 transition-colors cursor-pointer">
                          <h3 className="font-semibold">{role.title}</h3>
                          <p className="text-sm text-gray-500">{role.desc}</p> here</p>
                        </div>e</p>
                      </button>
                    ))}                </div>
                  </div>
                ) : (
                  <div className="space-y-4">
                  <button onClick={() => setSelectedRole(null)} className="text-sm text-blue-600">← Back</button>
                  <input type="password" value={passwordInput} onChange={(e) => setPasswordInput(e.target.value)} onKeyPress={(e) => e.key === 'Enter' && handleAdminLogin()} className="w-full px-4 py-3 border rounded-xl" placeholder="Password" />
                  {passwordError && <p className="text-red-500 text-sm">{passwordError}</p>}
                  <button onClick={handleAdminLogin} className="w-full py-3 bg-purple-600 text-white rounded-xl font-semibold">🔓 Access</button>
                  <p className="text-xs text-gray-400 text-center">Demo: medpact2026 | owner2026 | admin2026</p>
                </div>
                )}
              </div>
            </div>
          </div>
        </div>
      )}
    </div>
  );
};

export default Benchmarks;

